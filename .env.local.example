# Lead Depot local credentials template.
# Copy to `.env.local` and fill in real values. `.env.*` is gitignored so
# secrets stay off GitHub.
#
# Used by scripts/e2e-walkthrough.mjs and scripts/browser-matrix.mjs.
# Update whenever an admin password is rotated so smoke tests keep working.

# Walkthrough logs in as Nate (agent id=2, admin).
LD_EMAIL=nate@watsonbrothersgroup.com
LD_PASS=<nate-current-password>

# Alex (agent id=1, admin). Optional.
ALEX_EMAIL=alex@watsonbrothersgroup.com
# ALEX_PASS=<optional>

# Server-side shared secret for INGEST_SECRET-guarded admin endpoints
# (force-reset, holdouts admin, manual-appt, etc). Matches Railway env.
INGEST_SECRET=ms-ingest-2026
